{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CogniOS",
  "version": "0.1.0",
  "identifier": "com.cognios.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CogniOS",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/.cogios/search/extract/**",
            "$HOME/.cogios/voice-notes/**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
