{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main CogniOS window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/search-sidecar",
          "sidecar": true,
          "args": [
            "serve",
            "--storage-dir",
            { "validator": "^/[^\\x00]+$" }
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/search-sidecar",
          "sidecar": true,
          "args": [
            "serve",
            "--storage-dir",
            { "validator": "^/[^\\x00]+$" }
          ]
        }
      ]
    }
  ]
}
